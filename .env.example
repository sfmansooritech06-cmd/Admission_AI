# IBM watsonx.ai Credentials
IBM_API_KEY=your_ibm_api_key_here
IBM_PROJECT_ID=your_ibm_project_id_here
IBM_URL=https://us-south.ml.cloud.ibm.com

# Flask Settings
FLASK_SECRET_KEY=your_super_secret_flask_key_here
FLASK_DEBUG=False

# ── RAG Tuning (recommended values for 20+ college admission PDFs) ────────────
#
# CHUNK_SIZE    = 1200  captures a full fee table or eligibility block in one chunk
#                        (was 800 – too small for dense PDF tables)
#
# CHUNK_OVERLAP = 200   preserves sentence/paragraph context across chunk boundaries
#                        (was 100 – sentences were getting cut mid-way)
#
# TOP_K_RESULTS = 12    retrieves enough candidates to cover cross-college queries
#                        (was 5 – too few for 20+ college comparisons)
#
# CONFIDENCE_THRESHOLD = 0.30  below this cosine score the retriever auto-widens
#
# EMBEDDING_MODEL = all-mpnet-base-v2  better recall than MiniLM for longer docs;
#                   override with ibm/slate-125m-english-rtrvr if available on your
#                   IBM Cloud account via HuggingFaceEmbeddings
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K_RESULTS=12
CONFIDENCE_THRESHOLD=0.30
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# Vector Store Path
VECTORSTORE_PATH=vectorstore/faiss_index

# Data Path
DATA_PATH=data
